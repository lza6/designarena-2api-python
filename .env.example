# DesignArena 2API 配置文件示例
# 复制此文件为 .env 并根据实际情况修改

# ========== 服务器配置 ==========
DESIGNARENA_HOST=127.0.0.1
DESIGNARENA_PORT=8000
DESIGNARENA_API_MASTER_KEY=your_master_key_here

# ========== 性能配置 ==========
DESIGNARENA_MAX_CONCURRENT_TASKS=10
DESIGNARENA_REQUEST_TIMEOUT=30
DESIGNARENA_TASK_QUEUE_SIZE=100
DESIGNARENA_UI_REFRESH_INTERVAL=500

# ========== 速率限制 ==========
DESIGNARENA_RATE_LIMIT_PER_ACCOUNT=40
DESIGNARENA_RATE_LIMIT_WINDOW=60

# ========== Token 管理 ==========
DESIGNARENA_TOKEN_REFRESH_BEFORE_EXPIRY=10
DESIGNARENA_TOKEN_AUTO_REFRESH_INTERVAL=30
DESIGNARENA_TOKEN_DEFAULT_EXPIRY=60

# ========== 浏览器配置 ==========
DESIGNARENA_BASE_URL=https://www.designarena.ai
DESIGNARENA_BROWSER_HEADLESS=true
DESIGNARENA_BROWSER_TIMEOUT=60000

# ========== 日志配置 ==========
DESIGNARENA_DEBUG_MODE=false
DESIGNARENA_LOG_LEVEL=INFO
DESIGNARENA_LOG_RETENTION_DAYS=30

# ========== 历史数据 ==========
DESIGNARENA_MAX_HISTORY=1000
DESIGNARENA_METRICS_RETENTION_HOURS=24

# ========== 主题配置 ==========
DESIGNARENA_DEFAULT_THEME=DARK
